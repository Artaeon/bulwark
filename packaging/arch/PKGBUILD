# Maintainer: Raphael Lugmayr <raphael.lugmayr@stoicera.com>
pkgname=bulwark
pkgver=0.1.0
pkgrel=1
pkgdesc="Network security daemon for open/untrusted wireless networks"
arch=('x86_64' 'aarch64')
url="https://github.com/Artaeon/bulwark"
license=('MIT')
depends=('nftables' 'iproute2' 'iw')
optdepends=(
    'libnotify: desktop notifications for threats'
    'dhclient: lease file fallback for DHCP detection'
)
makedepends=('rust' 'cargo')
backup=('etc/bulwark/bulwark.toml')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
    cd "$pkgname-$pkgver"
    cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release --all-features
}

check() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    cargo test --frozen --release --all-features
}

package() {
    cd "$pkgname-$pkgver"

    # Binary
    install -Dm755 target/release/bulwark "$pkgdir/usr/bin/bulwark"

    # Config
    install -Dm644 bulwark.toml "$pkgdir/etc/bulwark/bulwark.toml"

    # Systemd unit
    install -Dm644 bulwark.service "$pkgdir/usr/lib/systemd/system/bulwark.service"

    # Documentation
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 SECURITY.md "$pkgdir/usr/share/doc/$pkgname/SECURITY.md"
    install -Dm644 EXAMPLES.md "$pkgdir/usr/share/doc/$pkgname/EXAMPLES.md"

    # License
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
